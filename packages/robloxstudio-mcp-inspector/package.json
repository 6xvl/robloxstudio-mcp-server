{
  "name": "@6xvl/robloxstudio-mcp-inspector",
  "version": "3.0.1",
  "description": "Read-only Roblox Studio MCP server (inspector edition). Extended fork.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "robloxstudio-mcp-inspector": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "studio-plugin/**/*"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "node ../../scripts/prepack.mjs",
    "postpack": "node ../../scripts/postpack.mjs"
  },
  "keywords": [
    "mcp",
    "roblox",
    "studio",
    "ai",
    "model-context-protocol",
    "inspector",
    "read-only"
  ],
  "author": "6xvl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/6xvl/robloxstudio-mcp-server.git"
  },
  "homepage": "https://github.com/6xvl/robloxstudio-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/6xvl/robloxstudio-mcp-server/issues"
  },
  "dependencies": {
    "@6xvl/robloxstudio-mcp-core": "3.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "node-fetch": "^3.3.2",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  }
}
